# Copy to .env and fill in your own values. Never commit .env.

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/restaurant

# Any long random string — used to sign login tokens
JWT_SECRET=change_me_to_a_long_random_string

# Base URL of the customer-facing site. This gets baked into every QR code,
# so it must be an address the scanning phone can actually reach:
#   local dev  → http://localhost:5173
#   phone test → http://<your-LAN-IP>:5173
#   production → https://your-site.vercel.app
FRONTEND_URL=http://localhost:5173

# Optional — hosts like Render set this automatically. Don't set it there.
PORT=5000

# Optional — leave blank to disable online payment.
# The app then falls back to pay-at-counter, confirmed by staff.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
